# Environment variables — NEVER commit these
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.local

# Remotion video — exclude heavy/generated files
video/node_modules/
video/out/
video/.cache/
# Root-level duplicates
nikitakondrashev-suspense-248067.mp3
# Rendered video outputs inside video/ subfolder
video/ou.mp4
video/out/*.mp4

# Google Cloud credentials — keep these off git
service-account*.json
*-credentials.json
gcloud*.json

# macOS
.DS_Store
.AppleDouble

# Editor
.idea/
.vscode/settings.json
*.swp
*.swo

# Logs
*.log
logs/
