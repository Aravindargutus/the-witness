# Copy this to .env and fill in your values
# Never commit .env to git

# Google Gemini API key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Cloud project ID (for Firestore + Cloud Run)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# Firestore database name (default is fine for most cases)
FIRESTORE_DATABASE=(default)

# Allowed CORS origins — comma-separated, no trailing slash
# Local dev: http://localhost:5178
# Production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5178

# Backend API URL (set after deploying to Cloud Run)
API_BASE_URL=http://localhost:8000

# Set to "production" in deployed environments
ENVIRONMENT=development
